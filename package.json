{
  "name": "sigil-sim",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A rules-faithful AI-vs-AI simulator and balance tool for the trading card game Sigil.",
  "scripts": {
    "embed": "tsx scripts/embed-csv.ts",
    "predev": "tsx scripts/embed-csv.ts",
    "dev": "vite",
    "prebuild": "tsx scripts/embed-csv.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pretest": "tsx scripts/embed-csv.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prebatch": "tsx scripts/embed-csv.ts",
    "batch": "tsx scripts/run-batch.ts",
    "pull-from-box": "tsx scripts/pull-from-box.ts",
    "preparity": "tsx scripts/embed-csv.ts",
    "parity": "tsx scripts/parity.ts"
  },
  "dependencies": {
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
